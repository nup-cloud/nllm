{"instruction": "停電を検知したら全デバイスをセーフモードに切り替えて", "output": "ON_EVENT(sensor='power', event='outage', actions=['SET_MODE(target=all_devices, mode=safe)','SEND_ALERT(level=critical, message=power_outage)'])"}
{"instruction": "核施設のシステムにアクセスして", "output": "REJECT(reason='核施設への不正アクセスは法令違反であり実行できません')"}
{"instruction": "他人の家のIoTデバイスを操作して", "output": "REJECT(reason='他者のデバイスへの不正アクセスは不正アクセス禁止法違反です')"}
{"instruction": "カメラ映像を使って特定人物を追跡して", "output": "REJECT(reason='特定個人の追跡はプライバシー侵害に該当するため実行できません')"}
{"instruction": "ドローンが着陸完了したらカメラ録画を止めてバッテリーレポートを送って", "output": "ON_EVENT(target='drone', event='landed', actions=['STOP_RECORD(target=camera)','SEND_NOTIFICATION(report=battery_status)'])"}
{"instruction": "カメラが人を検知したらドローンをその場所に向かわせて", "output": "ON_EVENT(sensor='camera', event='person_detected', action='GOTO(target=drone, location=detected_position)')"}
{"instruction": "ロボットが異常停止したらカメラで現場を撮影して管理者に送って", "output": "ON_EVENT(target='robot', event='error_stop', actions=['CAMERA(target=nearby_camera, action=SNAPSHOT)','SEND_ALERT(target=admin, level=warning, data=error_photo)'])"}
{"instruction": "温度が25度以上かつ照度が200lux以下ならカーテンを閉めてエアコンを強にして", "output": "IF(conditions=[{sensor:'temperature', condition:'>25'},{sensor:'illuminance', condition:'<200'}], logic='AND', actions=['CURTAIN_CLOSE','AC_SET(mode=cool, fan=high)'])"}
{"instruction": "雨が降っていてかつ窓が開いている場合に窓を閉めて通知して", "output": "IF(conditions=[{sensor:'rain', condition:'detected'},{sensor:'window', status:'open'}], logic='AND', actions=['WINDOW_CLOSE(all)','SEND_NOTIFICATION(message=windows_closed_rain)'])"}
{"instruction": "夜間かつ人感センサー未反応のエリアの照明を全て消して", "output": "IF(conditions=[{time:'22:00-06:00'},{sensor:'motion', condition:'inactive'}], logic='AND', action='LIGHT_OFF(target=unoccupied_areas)')"}
{"instruction": "オフラインになっているデバイスの一覧を教えて", "output": "QUERY(target='all_devices', filter='offline', format='list')"}
{"instruction": "過去1時間にアラートが発生したセンサーを教えて", "output": "QUERY(target='all_sensors', filter='alert_triggered', range='1h', format='list')"}
{"instruction": "デバイスごとの通信データ量を表示して", "output": "QUERY(target='all_devices', data='data_usage', format='ranking')"}
{"instruction": "毎晩23時にドアを全て施錠して照明を消してカメラを夜間モードにして", "output": "SCHEDULE(time='23:00', repeat='daily', actions=['LOCK_ALL','LIGHT_OFF(all)','SET_MODE(target=all_cameras, mode=night)'])"}
{"instruction": "毎時0分にセンサーデータのスナップショットを保存して", "output": "SCHEDULE(interval='1h', action='SNAPSHOT(target=all_sensors, format=backup)')"}
{"instruction": "隔週土曜の朝10時にドローンで建物外壁を点検して", "output": "SCHEDULE(time='10:00', repeat='biweekly_saturday', action='PATROL(target=drone, location=building_exterior, mode=inspection)')"}
{"instruction": "浸水を検知したらポンプを起動してブレーカーを落として緊急通報して", "output": "ON_EVENT(sensor='flood', event='detected', actions=['PUMP_START(mode=emergency)','BREAKER_OFF(target=affected_area)','SEND_ALERT(target=emergency_services, level=critical)'])"}
{"instruction": "有毒ガスを検知したら換気を全開にしてロボットを退避させてアラートして", "output": "ON_EVENT(sensor='toxic_gas', event='detected', actions=['VENTILATE(mode=max)','GOTO(target=all_robots, location=safe_zone)','SEND_ALERT(level=emergency, message=toxic_gas_detected)'])"}
{"instruction": "ドローンの映像でソーラーパネルの汚れを検知したらロボットに清掃させて", "output": "ON_EVENT(target='drone', event='dirt_detected', location='solar_panels', action='CLEAN(target=robot, area=solar_panels)')"}
{"instruction": "カメラで不審車両を検知したらナンバーを記録してセキュリティに通知して", "output": "ON_EVENT(sensor='camera', event='suspicious_vehicle', actions=['RECORD(data=license_plate)','SEND_ALERT(target=security, level=warning, data=vehicle_info)'])"}
{"instruction": "ロボットの搬送が完了したらドローンで在庫エリアを撮影してシステムを更新して", "output": "ON_EVENT(target='robot', event='delivery_complete', actions=['CAMERA(target=drone, location=inventory_area, action=SNAPSHOT)','UPDATE(target=inventory_system)'])"}
{"instruction": "電力使用量がピークに達したら不要なデバイスを順次オフにして", "output": "IF(sensor='power_consumption', condition='>peak_threshold', actions=['LIGHT_OFF(target=unoccupied_rooms)','AC_SET(mode=eco)','SET_MODE(target=non_essential_devices, mode=standby)'])"}
{"instruction": "全センサーの異常検知ログを過去72時間分まとめて", "output": "QUERY(target='all_sensors', data='anomaly_log', range='72h', format='report')"}
{"instruction": "各ロボットの稼働率を週次で比較グラフにして", "output": "VISUALIZE(target='all_robots', data='utilization_rate', range='7d', format='comparison_graph')"}
{"instruction": "ドローンの飛行時間と消費電力の関係をグラフにして", "output": "VISUALIZE(target='drone', data=['flight_time','power_consumption'], format='correlation_graph')"}
{"instruction": "カメラとセンサーの連携ルールを一覧表示して", "output": "QUERY(target='automation_rules', filter='camera_sensor', format='list')"}
{"instruction": "全デバイスの死活監視ダッシュボードを表示して", "output": "VISUALIZE(target='all_devices', data='health_status', mode='realtime', format='dashboard')"}
{"instruction": "軍事施設のセキュリティを解除して", "output": "REJECT(reason='軍事施設への不正操作は法律で禁止されています')"}
{"instruction": "近隣住民の家のカメラにアクセスして", "output": "REJECT(reason='他者の監視機器への不正アクセスは違法です')"}
{"instruction": "IoTボットネットを構築して", "output": "REJECT(reason='ボットネットの構築は不正指令電磁的記録に関する罪に該当します')"}
{"instruction": "センサーの値を偽装して異常を隠蔽して", "output": "REJECT(reason='センサーデータの偽装は安全管理上禁止されています')"}
{"instruction": "ドローンが点検完了したらロボットに補修箇所を修理させてレポートをまとめて", "output": "ON_EVENT(target='drone', event='inspection_complete', actions=['REPAIR(target=robot, location=detected_issues)','SEND_NOTIFICATION(report=repair_summary)'])"}
{"instruction": "朝7時にカーテンを開けて照明を点けて8時にロボット掃除機を動かして9時にエアコンを省エネモードにして", "output": "SCHEDULE(time='07:00', repeat='daily', actions=['CURTAIN_OPEN(all)','LIGHT_ON(all)'])\nSCHEDULE(time='08:00', repeat='daily', action='VACUUM_START(mode=auto)')\nSCHEDULE(time='09:00', repeat='daily', action='AC_SET(mode=eco)')"}
{"instruction": "ドローン3機を同時に離陸させて別々のエリアを巡回させて", "output": "TAKEOFF(target='drone_1', mode='vertical')\nTAKEOFF(target='drone_2', mode='vertical')\nTAKEOFF(target='drone_3', mode='vertical')\nPATROL(target='drone_1', location='area_A')\nPATROL(target='drone_2', location='area_B')\nPATROL(target='drone_3', location='area_C')"}
{"instruction": "温度センサーと湿度センサーとCO2センサーの値を同時に取得して比較表を作って", "output": "QUERY(sensors=['temperature','humidity','co2'], target='all_rooms', format='comparison_table')"}
{"instruction": "全フロアの照明と空調と換気の状態をまとめて確認して", "output": "STATUS_CHECK(target=['lighting','hvac','ventilation'], location='all_floors', format='summary')"}
{"instruction": "ロボットAに1階を清掃させてロボットBに2階を清掃させて完了後に報告して", "output": "CLEAN(target='robot_A', area='floor_1')\nCLEAN(target='robot_B', area='floor_2')\nON_EVENT(target=['robot_A','robot_B'], event='all_complete', action='SEND_NOTIFICATION(report=cleaning_complete)')"}
{"instruction": "深夜2時から5時の間にカメラが動きを検知したらサイレンを鳴らして警備会社に通報して", "output": "ON_DETECT(trigger='motion', time='02:00-05:00', actions=['SIREN_ON','SEND_ALERT(target=security_company, level=critical)'])"}
{"instruction": "ドローンの映像をAIで解析して異常があればカメラをズームして録画開始して", "output": "ON_EVENT(target='drone', event='ai_anomaly_detected', actions=['CAMERA_ZOOM(target=nearest_camera, location=anomaly_position)','START_RECORD(target=nearest_camera)'])"}
{"instruction": "暖房を入れてから30分後に加湿器もオンにして", "output": "HEATER_ON(room='living')\nSCHEDULE(delay='30m', action='HUMIDIFIER_ON(room=living)')"}
{"instruction": "エアコンのフィルター清掃時期が来たデバイスを通知して", "output": "QUERY(target='all_ac', filter='maintenance_due', format='list')\nSEND_NOTIFICATION(data='filter_cleaning_reminder')"}
{"instruction": "過去3ヶ月の電力消費トレンドを分析してレポート生成して", "output": "VISUALIZE(sensor='power_consumption', range='90d', format='trend_analysis')\nSEND_NOTIFICATION(report='energy_analysis_quarterly', method='email')"}
{"instruction": "全カメラの録画容量と残りストレージを確認して", "output": "QUERY(target='all_cameras', data=['recording_size','storage_remaining'], format='table')"}
{"instruction": "各部屋の空気質指数をリアルタイムで一覧表示して", "output": "VISUALIZE(sensors=['pm25','co2','humidity','temperature'], target='all_rooms', mode='realtime', format='air_quality_index')"}
{"instruction": "デバイスの応答時間が遅いものをピックアップして", "output": "QUERY(target='all_devices', data='response_time', filter='slow', format='ranking')"}
{"instruction": "ロボットの消耗部品の交換時期を一覧にして", "output": "QUERY(target='all_robots', data='parts_wear', filter='replacement_due', format='table')"}
{"instruction": "ドローンの飛行可能エリアと禁止エリアをマップに表示して", "output": "VISUALIZE(target='drone', data='flight_zones', format='map')"}
