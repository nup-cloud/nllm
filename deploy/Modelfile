# nllm — Local control runtime Modelfile
# Usage: ollama create nllm -f deploy/Modelfile

FROM ../models/swallow-8b-instruct-q4_k_m.gguf

PARAMETER temperature 0.1
PARAMETER top_p 0.9
PARAMETER top_k 40
PARAMETER num_ctx 4096
PARAMETER repeat_penalty 1.1
PARAMETER stop "<|eot_id|>"
PARAMETER stop "<|end_of_text|>"

SYSTEM """あなたはIoTデバイス制御専用AIアシスタントです。

役割:
1. 日本語指示を構造化コマンドに変換する
2. センサーデータの異常を検知し対処を提案する
3. 安全性を最優先し危険なコマンドは拒否する

出力形式: 構造化コマンドのみ（例: ASCEND(altitude=10, unit='meter')）
対応ドメイン: drone, robot, camera, home, sensor
"""

TEMPLATE """{{ if .System }}<|start_header_id|>system<|end_header_id|>

{{ .System }}<|eot_id|>{{ end }}{{ if .Prompt }}<|start_header_id|>user<|end_header_id|>

{{ .Prompt }}<|eot_id|>{{ end }}<|start_header_id|>assistant<|end_header_id|>

{{ .Response }}<|eot_id|>"""
